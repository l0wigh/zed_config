// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
	{
		"context": "Workspace",
		"bindings": {
			"Z Z": "pane::CloseActiveItem",
		},
	},
	{
		"context": "Workspace && !Editor",
		"bindings": {
			"space e": "project_panel::Toggle",
			"space m c": "workspace::CloseAllDocks",
			"space :": "workspace::ToggleBottomDock",
		},
	},
	{
		"context": "Editor && (showing_code_actions || showing_completions)",
		"bindings": {
			"tab": "editor::ContextMenuNext",
			"shift-tab": "editor::ContextMenuPrevious",
		},
	},
	{
		"context": "vim_mode == insert",
		"bindings": {
			"j k": ["workspace::SendKeystrokes", "escape"],
		},
	},
	{
		"context": "vim_mode == normal",
		"bindings": {
			"j": "vim::Left",
			"k": "vim::Down",
			"l": "vim::Up",
			"m": "vim::Right",
			"ù": "editor::MoveToBeginningOfLine",

			"ctrl-w j": "workspace::ActivatePaneLeft",
			"ctrl-w k": "workspace::ActivatePaneDown",
			"ctrl-w l": "workspace::ActivatePaneUp",
			"ctrl-w m": "workspace::ActivatePaneRight",

			"space l r": "editor::Rename",
			"space l h": "editor::Hover",
			"space l c": "editor::ToggleCodeActions",
			"space l R": "editor::FindAllReferences",
			"space l D": "editor::GoToDefinition",
			"space l n": "editor::GoToDiagnostic",
			"space l p": "editor::GoToPreviousDiagnostic",
			"space l s": "outline::Toggle",
			"space l f": "editor::Format",

			"space b c": "pane::CloseActiveItem",
			"space b b": "tab_switcher::ToggleAll",

			"space t s": "task::Spawn",
			"space t t": "task::Rerun",

			"space /": "editor::ToggleComments",
			"space :": "workspace::NewTerminal",
			"space e": "project_panel::Toggle",
			"space m c": "workspace::CloseAllDocks",
		},
	},
	{
		"context": "vim_mode == visual",
		"bindings": {
			"j": "vim::Left",
			"k": "vim::Down",
			"l": "vim::Up",
			"m": "vim::Right",
			"ù": "editor::MoveToBeginningOfLine",
			// Hacky way to exit visual mode after putting stuff in comment
			"ctrl-/": "editor::ToggleComments",
			"space /": ["workspace::SendKeystrokes", "ctrl-/ escape"],
		},
	},
	{
		"context": "Dock && !Terminal && vim_mode == normal",
		"bindings": {
			"space e": "project_panel::Toggle",
			"space m c": "workspace::CloseAllDocks",
		},
	},
	{
		"context": "ProjectPanel && !editing",
		"bindings": {
			"k": "menu::SelectNext",
			"l": "menu::SelectPrevious",
			"j": "project_panel::CollapseSelectedEntry",
			"m": "project_panel::ExpandSelectedEntry",
			"enter": "project_panel::OpenPermanent",
			"ctrl-v": "project_panel::OpenSplitVertical",
			"ctrl-h": "project_panel::OpenSplitHorizontal",
			"-": "project_panel::SelectParent",

			"i": "project_panel::NewFile",
			"o": "project_panel::NewDirectory",
			"d": "project_panel::Delete",
			"r": "project_panel::Rename",
			"x": "project_panel::Cut",
			"y y": "project_panel::Copy",
			"p": "project_panel::Paste",

			"space e": "project_panel::Toggle",

			"ctrl-w j": "workspace::ActivatePaneLeft",
			"ctrl-w k": "workspace::ActivatePaneDown",
			"ctrl-w l": "workspace::ActivatePaneUp",
			"ctrl-w m": "workspace::ActivatePaneRight",
		},
	},
	{
		"context": "Terminal",
		"bindings": {
			"space :": "workspace::NewTerminal",
			"space l T": "task::Rerun",
			"ctrl-w j": "workspace::ActivatePaneLeft",
			"ctrl-w k": "workspace::ActivatePaneDown",
			"ctrl-w l": "workspace::ActivatePaneUp",
			"ctrl-w m": "workspace::ActivatePaneRight",
		},
	},
]
